generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// SmallInt code conventions:
// status: 0=disabled, 1=enabled
// gender: 0=unknown, 1=male, 2=female
// menu.type: 1=directory, 2=menu, 3=link, 4=iframe
// permission.group: free-form categorization, e.g. "用户管理", "工单管理"
// user.data_scope: 1=all, 2=self, 3=self_dept, 4=self_dept_and_children, 5=custom_dept
// login_type: 1=password, 2=oauth, 3=oidc, 4=sso
// provider.type: 1=oauth2, 2=oidc, 3=saml, 4=ldap
// session.status: 1=active, 2=revoked, 3=expired
// login_logs.status: 0=failed, 1=success

model User {
  id           BigInt    @id @default(autoincrement())
  username     String    @db.VarChar(64)
  nickname     String?   @db.VarChar(64)
  realName     String?   @map("real_name") @db.VarChar(64)
  avatarFileId BigInt?   @map("avatar_file_id")
  email        String?   @db.VarChar(128)
  phone        String?   @db.VarChar(32)
  gender       Int       @default(0) @db.SmallInt
  status       Int       @default(1) @db.SmallInt
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  deptId       BigInt?   @map("dept_id")
  dataScope    Int       @default(2) @map("data_scope") @db.SmallInt
  remark       String?   @db.VarChar(512)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp  String?   @map("last_login_ip") @db.VarChar(64)
  createdBy    BigInt?   @map("created_by")
  updatedBy    BigInt?   @map("updated_by")
  deletedBy    BigInt?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  dept            Dept?              @relation("UserDept", fields: [deptId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  leadingDepts    Dept[]             @relation("DeptLeader")
  credential      UserCredential?
  userRoles       UserRole[]
  dataScopeDepts  UserDataScopeDept[]
  identities      UserIdentity[]
  sessions        AuthSession[]
  refreshTokens   RefreshToken[]
  loginLogs       LoginLog[]
  operationLogs   OperationLog[]
  avatarFile      File?              @relation("UserAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@unique([username, deletedId])
  @@unique([email, deletedId])
  @@unique([phone, deletedId])
  @@index([deptId])
  @@index([deletedId, status, createdAt])
  @@index([createdAt])
  @@map("users")
}

model UserCredential {
  id                 BigInt    @id @default(autoincrement())
  userId             BigInt    @unique @map("user_id")
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  passwordAlgo       String    @default("bcrypt") @map("password_algo") @db.VarChar(32)
  passwordVersion    Int       @default(1) @map("password_version")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz(3)
  passwordChangedAt  DateTime? @map("password_changed_at") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([lockedUntil])
  @@map("user_credentials")
}

model AuthProvider {
  id        BigInt   @id @default(autoincrement())
  code      String   @db.VarChar(64)
  name      String   @db.VarChar(128)
  type      Int      @db.SmallInt
  issuer    String?  @db.VarChar(255)
  config    Json?    @map("config_json")
  status    Int      @default(1) @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  identities UserIdentity[]

  @@unique([code])
  @@index([type])
  @@index([status])
  @@map("auth_providers")
}

model UserIdentity {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  providerId       BigInt    @map("provider_id")
  providerSubject  String    @map("provider_subject") @db.VarChar(255)
  providerUsername String?   @map("provider_username") @db.VarChar(128)
  providerEmail    String?   @map("provider_email") @db.VarChar(128)
  providerAvatar   String?   @map("provider_avatar") @db.VarChar(512)
  rawProfile       Json?     @map("raw_profile_json")
  linkedAt         DateTime  @default(now()) @map("linked_at") @db.Timestamptz(3)
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz(3)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  user     User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  provider AuthProvider @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([providerId, providerSubject, deletedId])
  @@unique([userId, providerId, deletedId])
  @@index([userId])
  @@index([providerId])
  @@index([deletedId])
  @@map("user_identities")
}

model Dept {
  id           BigInt    @id @default(autoincrement())
  parentId     BigInt?   @map("parent_id")
  name         String    @db.VarChar(64)
  code         String    @db.VarChar(64)
  sort         Int       @default(0)
  leaderUserId BigInt?   @map("leader_user_id")
  phone        String?   @db.VarChar(32)
  email        String?   @db.VarChar(128)
  status       Int       @default(1) @db.SmallInt
  remark       String?   @db.VarChar(512)
  createdBy    BigInt?   @map("created_by")
  updatedBy    BigInt?   @map("updated_by")
  deletedBy    BigInt?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  parent          Dept? @relation("DeptParent", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children        Dept[] @relation("DeptParent")
  leader          User? @relation("DeptLeader", fields: [leaderUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  users           User[] @relation("UserDept")
  dataScopeDepts  UserDataScopeDept[]

  @@unique([code, deletedId])
  @@index([parentId, sort])
  @@index([deletedId, parentId, sort])
  @@index([deletedId, status])
  @@index([sort])
  @@map("depts")
}

model Role {
  id        BigInt    @id @default(autoincrement())
  code      String    @db.VarChar(64)
  name      String    @db.VarChar(64)
  sort      Int       @default(0)
  status    Int       @default(1) @db.SmallInt
  isSystem  Boolean   @default(false) @map("is_system")
  remark    String?   @db.VarChar(512)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  userRoles        UserRole[]
  roleMenus        RoleMenu[]
  rolePermissions  RolePermission[]

  @@unique([code, deletedId])
  @@index([deletedId, status, sort])
  @@index([sort])
  @@map("roles")
}

model UserRole {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdBy BigInt?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Menu {
  id           BigInt    @id @default(autoincrement())
  parentId     BigInt?   @map("parent_id")
  type         Int       @db.SmallInt
  name         String    @db.VarChar(128)
  title        String    @db.VarChar(128)
  path         String?   @db.VarChar(255)
  component    String?   @db.VarChar(255)
  redirect     String?   @db.VarChar(255)
  icon         String?   @db.VarChar(128)
  sort         Int       @default(0)
  hidden       Int       @default(0) @db.SmallInt
  keepAlive    Int       @default(0) @map("keep_alive") @db.SmallInt
  alwaysShow   Int       @default(0) @map("always_show") @db.SmallInt
  externalUrl  String?   @map("external_url") @db.VarChar(512)
  activeMenuId BigInt?   @map("active_menu_id")
  status       Int       @default(1) @db.SmallInt
  remark       String?   @db.VarChar(512)
  createdBy    BigInt?   @map("created_by")
  updatedBy    BigInt?   @map("updated_by")
  deletedBy    BigInt?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  parent       Menu?  @relation("MenuParent", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children     Menu[] @relation("MenuParent")
  activeMenu   Menu?  @relation("MenuActiveMenu", fields: [activeMenuId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  linkedMenus  Menu[] @relation("MenuActiveMenu")
  roleMenus    RoleMenu[]

  @@unique([name, deletedId])
  @@index([parentId, sort])
  @@index([activeMenuId])
  @@index([type])
  @@index([deletedId, parentId, sort])
  @@index([deletedId, status, sort])
  @@index([sort])
  @@map("menus")
}

model RoleMenu {
  id        BigInt   @id @default(autoincrement())
  roleId    BigInt   @map("role_id")
  menuId    BigInt   @map("menu_id")
  createdBy BigInt?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([roleId, menuId])
  @@index([menuId])
  @@map("role_menus")
}

model Permission {
  id        BigInt    @id @default(autoincrement())
  code      String    @db.VarChar(128)
  name      String    @db.VarChar(128)
  group     String?   @db.VarChar(64)
  method    String?   @db.VarChar(16)
  path      String?   @db.VarChar(255)
  sort      Int       @default(0)
  status    Int       @default(1) @db.SmallInt
  isSystem  Boolean   @default(false) @map("is_system")
  remark    String?   @db.VarChar(512)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  rolePermissions RolePermission[]

  @@unique([code, deletedId])
  @@index([method, path])
  @@index([group])
  @@index([deletedId, status])
  @@map("permissions")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement())
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdBy    BigInt?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserDataScopeDept {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  deptId    BigInt   @map("dept_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  dept Dept @relation(fields: [deptId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, deptId])
  @@index([deptId])
  @@map("user_data_scope_depts")
}

model DictType {
  id        BigInt    @id @default(autoincrement())
  code      String    @db.VarChar(64)
  name      String    @db.VarChar(64)
  status    Int       @default(1) @db.SmallInt
  isSystem  Boolean   @default(false) @map("is_system")
  remark    String?   @db.VarChar(512)
  createdBy BigInt?   @map("created_by")
  updatedBy BigInt?   @map("updated_by")
  deletedBy BigInt?   @map("deleted_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  items DictItem[]

  @@unique([code, deletedId])
  @@index([deletedId, status])
  @@map("dict_types")
}

model DictItem {
  id         BigInt    @id @default(autoincrement())
  dictTypeId BigInt    @map("dict_type_id")
  label      String    @db.VarChar(128)
  value      String    @db.VarChar(128)
  color      String?   @db.VarChar(32)
  cssClass   String?   @map("css_class") @db.VarChar(128)
  sort       Int       @default(0)
  status     Int       @default(1) @db.SmallInt
  isDefault  Boolean   @default(false) @map("is_default")
  remark     String?   @db.VarChar(512)
  createdBy  BigInt?   @map("created_by")
  updatedBy  BigInt?   @map("updated_by")
  deletedBy  BigInt?   @map("deleted_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(3)
  deletedId    BigInt    @default(0) @map("deleted_id")

  dictType DictType @relation(fields: [dictTypeId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([dictTypeId, value, deletedId])
  @@index([dictTypeId, deletedId, status, sort])
  @@index([sort])
  @@map("dict_items")
}

model AuthSession {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  loginType    Int       @map("login_type") @db.SmallInt
  provider     String    @default("local") @db.VarChar(64)
  ip           String?   @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.Text
  deviceName   String?   @map("device_name") @db.VarChar(128)
  status       Int       @default(1) @db.SmallInt
  lastActiveAt DateTime? @map("last_active_at") @db.Timestamptz(3)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  revokeReason String?   @map("revoke_reason") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([userId, status])
  @@index([expiresAt])
  @@index([lastActiveAt])
  @@map("auth_sessions")
}

model RefreshToken {
  id                BigInt    @id @default(autoincrement())
  userId            BigInt    @map("user_id")
  sessionId         BigInt    @map("session_id")
  tokenHash         String    @unique @map("token_hash") @db.VarChar(255)
  familyId          BigInt    @map("family_id")
  parentId          BigInt?   @map("parent_id")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(3)
  replacedByTokenId BigInt?   @map("replaced_by_token_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  session AuthSession @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId])
  @@index([sessionId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginLog {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @map("user_id")
  username      String?  @db.VarChar(128)
  loginType     Int      @map("login_type") @db.SmallInt
  provider      String   @default("local") @db.VarChar(64)
  ip            String?  @db.VarChar(64)
  location      String?  @db.VarChar(128)
  userAgent     String?  @map("user_agent") @db.Text
  browser       String?  @db.VarChar(64)
  os            String?  @db.VarChar(64)
  device        String?  @db.VarChar(64)
  status        Int      @db.SmallInt
  failureReason String?  @map("failure_reason") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, createdAt])
  @@index([username, createdAt])
  @@index([status, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
  @@map("login_logs")
}

model OperationLog {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @map("user_id")
  username      String?  @db.VarChar(128)
  module        String?  @db.VarChar(64)
  action        String?  @db.VarChar(64)
  description   String?  @db.VarChar(255)
  method        String?  @db.VarChar(16)
  path          String?  @db.VarChar(255)
  ip            String?  @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.Text
  requestId     String?  @map("request_id") @db.VarChar(64)
  requestParams Json?    @map("request_params")
  requestBody   Json?    @map("request_body")
  statusCode    Int?     @map("status_code")
  success       Boolean  @default(false)
  errorMessage  String?  @map("error_message") @db.Text
  durationMs    Int?     @map("duration_ms")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, createdAt])
  @@index([action])
  @@index([module, action])
  @@index([success, createdAt])
  @@index([requestId])
  @@index([createdAt])
  @@map("operation_logs")
}

model File {
  id           BigInt    @id @default(autoincrement())
  originalName String    @map("original_name") @db.VarChar(255)
  objectKey    String    @unique @map("object_key") @db.VarChar(512)
  mimeType     String    @map("mime_type") @db.VarChar(128)
  size         BigInt
  bucketName   String    @map("bucket_name") @db.VarChar(128)
  createdBy    BigInt?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedBy    BigInt?   @map("updated_by")
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  userAvatars   User[]             @relation("UserAvatar")
  fileRelations FileRelation[]

  @@index([createdBy])
  @@index([createdAt])
  @@map("files")
}

model FileRelation {
  id        BigInt   @id @default(autoincrement())
  fileId    BigInt   @map("file_id")
  refTable  String   @map("ref_table") @db.VarChar(64)
  refId     BigInt   @map("ref_id")
  refField  String   @map("ref_field") @db.VarChar(64)
  createdBy BigInt?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([fileId, refTable, refId, refField])
  @@index([refTable, refId])
  @@index([refTable, refId, refField])
  @@map("file_relations")
}

model Notice {
  id            BigInt    @id @default(autoincrement())
  title         String    @db.VarChar(255)
  content       String    @db.Text
  type          Int       @db.SmallInt
  level         String    @default("L") @db.VarChar(32)
  targetType    Int       @default(1) @db.SmallInt
  targetUserIds Json?     @map("target_user_ids")
  publishStatus Int       @default(0) @db.SmallInt
  publisherId   BigInt?   @map("publisher_id")
  publishTime   DateTime? @map("publish_time") @db.Timestamptz(3)
  revokeTime    DateTime? @map("revoke_time") @db.Timestamptz(3)
  createdBy     BigInt?   @map("created_by")
  updatedBy     BigInt?   @map("updated_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)

  readRecords NoticeReadRecord[]

  @@index([publishStatus, publishTime])
  @@index([createdAt])
  @@map("notices")
}

model NoticeReadRecord {
  id       BigInt   @id @default(autoincrement())
  noticeId BigInt   @map("notice_id")
  userId   BigInt   @map("user_id")
  readAt   DateTime @default(now()) @map("read_at") @db.Timestamptz(3)

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([noticeId, userId])
  @@index([userId, readAt])
  @@map("notice_read_records")
}

