# 运行环境
NODE_ENV=development

# 应用配置
APP_NAME=nest-prisma-admin
APP_PORT=3000
GLOBAL_PREFIX=api

# PostgreSQL 数据库
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:123456@localhost:5432/nest_prisma_admin?schema=public

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Swagger
SWAGGER_ENABLE=true
SWAGGER_PATH=api-docs
SWAGGER_TITLE=nest-prisma-admin
SWAGGER_DESCRIPTION=API 文档
SWAGGER_VERSION=1.0.0

# Security / JWT
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_ISSUER=nest-prisma-admin
JWT_AUDIENCE=nest-prisma-admin-client

# Refresh Token
REFRESH_EXPIRES_IN=7d
REFRESH_TTL_DAYS=30

# Captcha
CAPTCHA_EXPIRES_IN=5
CAPTCHA_LENGTH=4

# Login lock
LOCK_THRESHOLD=5
LOCK_DURATION=15

# Captcha
CAPTCHA_ENABLE=true

# RSA 密码传输加密
RSA_ENABLE=true
RSA_KEY_BITS=2048
RSA_TTL_SECONDS=300
RSA_ROTATE_SECONDS=150

# MinIO / S3 对象存储
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nest-prisma-admin
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600
# 单位: MB
S3_MAX_FILE_SIZE=50

# OAuth
OAUTH_FRONTEND_URL=http://localhost:5173
# 后端访问 Google/GitHub OAuth API 的代理（国内必须配），留空则不走代理
HTTPS_PROXY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/github/callback

# Gitee OAuth
GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=
GITEE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/gitee/callback

# Seed
SEED_ADMIN_PASSWORD=admin123
